#include <stdio.h>

int main() {
    int i,j;
    int rows, cols, parityType;
    printf("Enter number of rows: ");
    scanf("%d", &rows);
    printf("Enter number of columns: ");
    scanf("%d", &cols);

    printf("Enter parity type:\n1. Even parity\n2. Odd parity\nEnter your choice: ");
    scanf("%d", &parityType);

    int data[rows][cols];
    printf("Enter the received data:\n");
    for (i = 0; i < rows; i++)
        for (j = 0; j < cols; j++)
            scanf("%d", &data[i][j]);

    int rowerror = 0, colerror = 0;

    for (i = 0; i < rows - 1; i++) {
        int sum = 0;
        for (j = 0; j < cols - 1; j++)
            sum += data[i][j];

        if ((sum % 2 == 0 && parityType == 2) || (sum % 2 == 1 && parityType == 1)) {
            if (data[i][cols - 1] != 1)
                rowerror = 1;
        } else {
            if (data[i][cols - 1] != 0)
                rowerror = 1;
        }
    }

    for (j = 0; j < cols - 1; j++) {
        int sum = 0;
        for (i = 0; i < rows - 1; i++)
            sum += data[i][j];

        if ((sum % 2 == 0 && parityType == 2) || (sum % 2 == 1 && parityType == 1)) {
            if (data[rows - 1][j] != 1)
                colerror = 1;
        } else {
            if (data[rows - 1][j] != 0)
                colerror = 1;
        }
    }

    if (rowerror == 0 && colerror == 0)
        printf("\nNo error detected.\n");
    else
        printf("\nError detected!\n");

    return 0;
}
