// UDP server
#include <stdio.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <string.h>
#include <stdlib.h>
#include <sys/types.h>
#include <arpa/inet.h>

int main() {
    int i, sd, b, len;
    char str1[100];
    int cost = 0;
    char dup = '\0';

    struct sockaddr_in server, client;

    server.sin_family = AF_INET;
    server.sin_port = htons(5459);
    server.sin_addr.s_addr = htonl(INADDR_ANY);

    sd = socket(AF_INET, SOCK_DGRAM, 0);
    if (sd > 0)
        printf("Socket successful\n");
    else {
        printf("Socket not successful\n");
        return 1;
    }

    b = bind(sd, (struct sockaddr *)&server, sizeof(server));
    if (b >= 0)
        printf("Bind successful\n");
    else {
        printf("Bind not successful\n");
        close(sd);
        return 1;
    }

    len = sizeof(client);
    recvfrom(sd, str1, sizeof(str1), 0, (struct sockaddr *)&client, &len);
    printf("Client: %s\n", str1);

    cost = 0;
    dup = '\0';
    for (i = 0; i < strlen(str1); i++) {
        if (dup != str1[i]) {
            cost++;
            dup = str1[i];
        } else {
            dup = '\0';
        }
    }

    printf("Cost = %d\n", cost);
    sendto(sd, &cost, sizeof(cost), 0, (struct sockaddr *)&client, len);

    close(sd);
    return 0;
}



// UDP client
#include <stdio.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <string.h>
#include <stdlib.h>
#include <sys/types.h>
#include <arpa/inet.h>

int main() {
    int sd, len, cost;
    char str1[100];
    struct sockaddr_in server;

    server.sin_family = AF_INET;
    server.sin_port = htons(5459);
    server.sin_addr.s_addr = htonl(INADDR_ANY);

    sd = socket(AF_INET, SOCK_DGRAM, 0);
    if (sd > 0)
        printf("Socket successful\n");
    else {
        printf("Socket not successful\n");
        return 1;
    }

    len = sizeof(server);

    printf("Enter jewel string: ");
    scanf("%s", str1);

    sendto(sd, str1, strlen(str1) + 1, 0, (struct sockaddr *)&server, len);
    recvfrom(sd, &cost, sizeof(cost), 0, (struct sockaddr *)&server, &len);

    printf("Server: Minimum Cost = %d\n", cost);

    close(sd);
    return 0;
}
