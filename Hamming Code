// Hamming Code Sender
#include <stdio.h>
#include <math.h>

int powfn(int base, int expo){
   int i;
   int result =1;
   for (i = 0; i < expo; i++) {
       result *= base;
   }
   return result;
}
int calculate_parity(int m) {
    int r = 0;
    while (powfn(2,r) < (m + r + 1)) {
        r++;
    }
    return r;
}

void parityValues(int ham[], int total) {
   int i,j;
   for (i = 1; i <= total; i <<= 1) {
        int parity = 0;
        for (j = 1; j <= total; j++) {
            if (j & i) {
                if (j != i) {
                    parity ^= ham[j];
                }
            }
        }
        ham[i] = parity;
    }
}

int main() {
    int n, i;
    int data[100];

    printf("Enter size of data: ");
    scanf("%d", &n);

    printf("Enter data bits: ");
    for (i = 0; i < n; i++) {
        scanf("%d", &data[i]);
    }

    int p = calculate_parity(n);
    int totalbits = n + p;

    int ham[totalbits + 1];
    for (i = 1; i <= totalbits; i++) {
        ham[i] = 0;
    }

    int j = 0;
    for (i = 1; i <= totalbits; i++) {
        if ((i & (i - 1)) == 0) {
            continue;
        }
        ham[i] = data[j++];
    }

    parityValues(ham, totalbits);

    printf("\nGenerated Hamming code: ");
    for (i = totalbits; i >= 1; i--) {
        printf("%d", ham[i]);
    }

    return 0;
}


// Hamming Code Receiver
#include <stdio.h>

int errorDetect(int ham[], int totalbits) {
    int e = 0;
int i,j;
    for (i = 1; i <= totalbits; i <<= 1) {
        int parity = 0;
        for (j = 1; j <= totalbits; j++) {
            if (j & i) {
                parity ^= ham[j];
            }
        }
        if (parity == 1) {
            e += i;
        }
    }
    return e;
}

int main() {
    int n, i;

    printf("Enter size of received codeword: ");
    scanf("%d", &n);

    int ham[n+1];
    printf("Enter received bits: ");
    for (i = n; i >= 1; i--) {
        scanf("%d", &ham[i]);
    }

    int error = errorDetect(ham, n);

    if (error == 0) {
        printf("No error detected\n");
    } else {
        printf("Error detected at bit position: %d\n", error);

        ham[error] ^= 1;
        printf("Corrected codeword: ");
        for (i = n; i >= 1; i--) {
            printf("%d", ham[i]);
        }
        printf("\n");
    }

    return 0;
}
