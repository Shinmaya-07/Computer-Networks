
// TCP server
#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <sys/types.h>
#include <arpa/inet.h>
int main()
{
    int i, sd, b, l, ac, len;
    int min, max;
    char str1[100], str2[100], result[50];
    struct sockaddr_in server, client;
    server.sin_family = AF_INET;
    server.sin_port = htons(5501);
    server.sin_addr.s_addr = htonl(INADDR_ANY);
    sd = socket(AF_INET, SOCK_STREAM, 0);
    if (sd > 0)
        printf("Created\n");
    else {
        printf("Not created\n");
        exit(0);
    }
    b = bind(sd, (struct sockaddr *)&server, sizeof(server));
    if (b == 0)
        printf("Binded\n");
    else {
        printf("Not binded\n");
        exit(0);
    }
    l = listen(sd, 5);
    if (l == 0)
        printf("Listening...\n");
    else {
        printf("Not listening\n");
        exit(0);
    }
        len = sizeof(client);
    ac = accept(sd, (struct sockaddr *)&client, &len);
    if (ac > 0)
        printf("Accepted\n");
    else {
        printf("Not accepted\n");
        exit(0);
    }
    recv(ac, str1, 100, 0);
    recv(ac, str2, 100, 0);
    printf("Received strings:\n%s\n%s\n", str1, str2);
    int len1 = strlen(str1);
    int len2 = strlen(str2);
    int min_length = len1 < len2 ? len1 : len2;
    min = 0;
    max = 0;
    for (i = 0; i < min_length; i++) {
        if (str1[i] == '?' || str2[i] == '?' || str1[i] != str2[i]) {
                          max++;
        }
        if (str1[i] != '?' && str2[i] != '?' && str1[i] != str2[i]) {
            min++;
        }
    }

    if (len1 > len2) {
        max += len1 - len2;
    } else if (len2 > len1) {
        max += len2 - len1;
    }
    sprintf(result, "%d %d", min, max);
    send(ac, result, sizeof(result), 0);
    printf("Result sent: %s\n", result);
    close(ac);
    close(sd);
    return 0;
}


// TCP client
#include <stdio.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <string.h>
#include <stdlib.h>
#include <sys/types.h>
#include <arpa/inet.h>

int main()
{
    int sd, c, len;
    char str1[100], str2[100], result[50];
    struct sockaddr_in server;

    server.sin_family = AF_INET;
    server.sin_port = htons(5501);
    server.sin_addr.s_addr = htonl(INADDR_ANY);

    sd = socket(AF_INET, SOCK_STREAM, 0);
    if (sd > 0)
        printf("Created\n");
    else {
        printf("Not created\n");
        exit(0);
    }

    len = sizeof(server);
    c = connect(sd, (struct sockaddr *)&server, len);
    if (c == 0)
        printf("Connected to server\n");
    else {
        printf("Connection failed\n");
        exit(0);
    }

    printf("\nEnter first string : ");
    scanf("%s", str1);
    send(sd, str1, 100, 0);

    printf("Enter second string: ");
    scanf("%s", str2);
    send(sd, str2, 100, 0);

    recv(sd, result, sizeof(result), 0);
    result[sizeof(result)-1] = '\0';

    printf("\nServer Response (min max): %s\n", result);

    close(sd);
    return 0;
}
