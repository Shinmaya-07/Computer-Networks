#include <stdio.h>
#include <string.h>

int main() {
    FILE *infile, *outfile;
    char input[200];
    char output[200];
    int i, count = 0, j = 0;
    char data[200];
    printf("Enter Data = ");
    scanf("%s",data);
    infile = fopen("bit_input.txt", "w");
    fprintf(infile, "%s", data);
    fclose(infile);
    infile = fopen("bit_input.txt","r");
    if(infile == NULL)
    {
       printf("Error Opening in file.");
    }
       fgets(input, sizeof(input), infile);
       fclose(infile);

    strcpy(output, "01111110");
    j = strlen(output);

    for (i = 0; input[i] != '\0'; i++) {
        if (input[i] == '1') {
            count++;
            output[j++] = input[i];
            if (count == 5) {
                output[j++] = '0';
                count = 0;
            }
        } else {
            output[j++] = input[i];
            count = 0;
        }
    }

    strcat(output, "01111110");

    outfile = fopen("bit_stuffed.txt", "w");
    if (outfile == NULL) {
        printf("Cannot open bit_stuffed.txt\n");
        return 1;
    }

    fprintf(outfile, "%s", output);
    fclose(outfile);

    printf("Bit Stuffing done. Check bit_stuffed.txt\n");
    return 0;
}
