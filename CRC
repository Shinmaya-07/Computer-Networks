//CRC sender
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void xorOperation(char *temp, const char *divisor, int len) {
   int i;
   for (i = 1; i < len; i++) {
        if(temp[i] == divisor[i]){
           temp[i-1] = '0';
        }
        else{
           temp[i-1]= '1';
        }
    }
}

int main() {
    int i, dn, divisorLen;

    printf("Enter number of bits in data: ");
    scanf("%d", &dn);

    printf("Enter number of bits in divisor: ");
    scanf("%d", &divisorLen);

    char *data = (char *)malloc((dn + divisorLen) * sizeof(char));
    char *divisor = (char *)malloc((divisorLen + 1) * sizeof(char));

    printf("Enter data bits: ");
    for (i = 0; i < dn; i++) {
        scanf(" %c", &data[i]);
    }

    printf("Enter divisor bits: ");
    for (i = 0; i < divisorLen; i++) {
        scanf(" %c", &divisor[i]);
    }
    divisor[divisorLen] = '\0';

    for (i = 0; i < divisorLen - 1; i++) {
        data[dn + i] = '0';
    }
    data[dn + divisorLen - 1] = '\0';

    char temp[100];
    strncpy(temp, data, divisorLen);
    temp[divisorLen] = '\0';

    int curr = divisorLen;

    while (curr <= dn + divisorLen - 1) {
        if (temp[0] == '1') {
            xorOperation(temp, divisor, divisorLen);
        } else {
            char zeroDiv[20];
            for (i = 0; i < divisorLen; i++) zeroDiv[i] = '0';
            zeroDiv[divisorLen] = '\0';
            xorOperation(temp, zeroDiv, divisorLen);
        }

        temp[divisorLen - 1] = data[curr];
        curr++;
    }

    printf("CRC bits: ");
    for (i = 0; i < divisorLen - 1; i++) {
        printf("%c", temp[i]);
    }

    printf("\nTransmitted Data: ");
    for (i = 0; i < dn; i++) {
        printf("%c", data[i]);
    }
    for (i = 0; i < divisorLen - 1; i++) {
        printf("%c", temp[i]);
    }

    printf("\n");

    free(data);
    free(divisor);

    return 0;
}

//CRC receiver
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void findxor(char *data, char *key, char *result, int len) {
   int i;
   for (i = 0; i < len; i++) {
        if(data[i] == key[i]){
           result[i] = '0';
        }
        else{
           result[i] = '1';
        }
    }
    result[len] = '\0';
}

int main() {
    int dn, ds, i;

    printf("Enter size of data (with CRC bits): ");
    scanf("%d", &dn);

    printf("Enter size of divisor: ");
    scanf("%d", &ds);

    char *data = (char *)malloc((dn + 1) * sizeof(char));
    char *divisor = (char *)malloc((ds + 1) * sizeof(char));

    printf("Enter received data (with CRC): ");
    for (i = 0; i < dn; i++) {
        scanf(" %c", &data[i]);
    }
    data[dn] = '\0';

    printf("Enter divisor bits: ");
    for (i = 0; i < ds; i++) {
        scanf(" %c", &divisor[i]);
    }
    divisor[ds] = '\0';

    char temp[100], remainder[100];
    strncpy(temp, data, ds);
    temp[ds] = '\0';

    int curr = ds;

    while (curr < dn) {
        if (temp[0] == '1') {
            findxor(temp, divisor, remainder, ds);
        } else {
            char zeros[ds + 1];
            for (i = 0; i < ds; i++) zeros[i] = '0';
            zeros[ds] = '\0';
            findxor(temp, zeros, remainder, ds);
        }

        for (i = 0; i < ds - 1; i++) {
            temp[i] = remainder[i + 1];
        }
        temp[ds - 1] = data[curr];
        curr++;
    }

    if (temp[0] == '1') {
        findxor(temp, divisor, remainder, ds);
    } else {
        char zeros[ds + 1];
        for (i = 0; i < ds; i++) zeros[i] = '0';
        zeros[ds] = '\0';
        findxor(temp, zeros, remainder, ds);
    }

    int error = 0;
    for (i = 0; i < ds - 1; i++) {
        if (remainder[i] != '0') {
            error = 1;
            break;
        }
    }

    if (error)
        printf("Received Data has ERROR\n");
    else
        printf("Received Data has NO ERROR\n");

    free(data);
    free(divisor);

    return 0;
}
