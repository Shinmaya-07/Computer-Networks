// TCP server
#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <sys/types.h>
#include <arpa/inet.h>

int main()
{
    int i, j, sd, b, l, ac, len;
    int n, arr[100], dup[100], count = 0;
    char result[500];
    struct sockaddr_in server, client;

    server.sin_family = AF_INET;
    server.sin_port = htons(5391);
    server.sin_addr.s_addr = htonl(INADDR_ANY);

    sd = socket(AF_INET, SOCK_STREAM, 0);
    if (sd > 0)
        printf("Created\n");
    else {
        printf("Not created\n");
        exit(0);
    }

    b = bind(sd, (struct sockaddr *)&server, sizeof(server));
    if (b == 0)
        printf("Binded\n");
    else {
        printf("Not binded\n");
        exit(0);
    }

    l = listen(sd, 5);
    if (l == 0)
        printf("Listening...\n");
    else {
        printf("Not listening\n");
        exit(0);
    }

    len = sizeof(client);
    ac = accept(sd, (struct sockaddr *)&client, &len);
    if (ac > 0)
        printf("Accepted\n");
    else {
        printf("Not accepted\n");
        exit(0);
    }

    recv(ac, &n, sizeof(n), 0);
    printf("\nReceived %d elements from client.\n", n);

    recv(ac, arr, sizeof(int) * n, 0);

    count = 0;
    for (i = 0; i < n; i++) {
        int found = 0;
        for (j = 0; j < count; j++) {
            if (arr[i] == dup[j]) {
                found = 1;
                break;
            }
        }
        if (!found) {
            dup[count] = arr[i];
            count++;
        }
    }

    sprintf(result, "Unique Count: %d\nElements: ", count);
    for (i = 0; i < count; i++) {
        char temp[20];
        sprintf(temp, "%d ", dup[i]);
        strcat(result, temp);
    }

    send(ac, result, sizeof(result), 0);
    printf("\nResult sent to client.\n");

    close(ac);
    close(sd);
    return 0;
}



//TCP Client
#include <stdio.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <string.h>
#include <stdlib.h>
#include <sys/types.h>
#include <arpa/inet.h>

int main()
{
    int i, sd, c, len, n, arr[100];
    char result[500];
    struct sockaddr_in server;

    server.sin_family = AF_INET;
    server.sin_port = htons(5391);
    server.sin_addr.s_addr = htonl(INADDR_ANY);

    sd = socket(AF_INET, SOCK_STREAM, 0);
    if (sd > 0)
        printf("Created\n");
    else {
        printf("Not created\n");
        exit(0);
    }

    len = sizeof(server);
    c = connect(sd, (struct sockaddr *)&server, len);
    if (c == 0)
        printf("Connected to server\n");
    else {
        printf("Connection failed\n");
        exit(0);
    }

    printf("\nEnter number of elements: ");
    scanf("%d", &n);

    printf("Enter %d integers: ", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    send(sd, &n, sizeof(n), 0);

    send(sd, arr, sizeof(int) * n, 0);

    recv(sd, result, sizeof(result), 0);
    result[sizeof(result) - 1] = '\0';

    printf("\nServer Response:\n%s\n", result);

    close(sd);
    return 0;
}
